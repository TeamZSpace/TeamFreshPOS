{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Inventory products.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "current_selling_price": { "type": "number", "description": "Retail price" },
        "average_cost_price": { "type": "number", "description": "Weighted average cost" },
        "total_stock": { "type": "number", "description": "Current stock level" },
        "categoryId": { "type": "string" },
        "supplierId": { "type": "string" },
        "productCode": { "type": "string" },
        "brand": { "type": "string" },
        "dosage": { "type": "string" },
        "unitCount": { "type": "string" },
        "dosageForm": { "type": "string" },
        "expiryDate": { "type": "string" },
        "purchaseDate": { "type": "string" }
      },
      "required": ["name", "current_selling_price", "average_cost_price", "total_stock"]
    },
    "Purchase": {
      "title": "Purchase",
      "description": "Inventory purchase records.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "product_id": { "type": "string" },
        "qty": { "type": "number" },
        "purchase_price": { "type": "number" },
        "current_selling_price": { "type": "number" },
        "shipping": { "type": "number" },
        "supplierId": { "type": "string" },
        "categoryId": { "type": "string" },
        "total_amount": { "type": "number" }
      },
      "required": ["date", "product_id", "qty", "purchase_price", "current_selling_price", "shipping", "total_amount"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Customer sales records.",
      "type": "object",
      "properties": {
        "order_no": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "customer_id": { "type": "string" },
        "total_amount": { "type": "number" },
        "payment_status": { "type": "string", "enum": ["Paid", "Unpaid", "Partial"] },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "product_id": { "type": "string" },
              "qty": { "type": "number" },
              "sold_price_snapshot": { "type": "number" },
              "cost_price_snapshot": { "type": "number" }
            }
          }
        },
        "paymentMethod": { "type": "string" },
        "address": { "type": "string" },
        "deliveryDate": { "type": "string" },
        "subtotal": { "type": "number" },
        "gross_amount": { "type": "number" },
        "tax_amount": { "type": "number" },
        "net_amount": { "type": "number" },
        "deliveryFees": { "type": "number" },
        "profit": { "type": "number" }
      },
      "required": ["order_no", "date", "customer_id", "items", "total_amount"]
    },
    "Customer": {
      "title": "Customer",
      "description": "CRM customer records.",
      "type": "object",
      "properties": {
        "facebookName": { "type": "string" },
        "orderName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "points": { "type": "number", "description": "Loyalty points" },
        "orderCount": { "type": "number", "description": "Total number of orders" },
        "lastOrderDate": { "type": "string", "format": "date-time" }
      },
      "required": ["facebookName"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Product suppliers.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contactPerson": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["name"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "parent": { "type": "string", "description": "Reference to parent Category ID" }
      },
      "required": ["name"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expenses.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" }
      },
      "required": ["date", "amount", "category"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Company settings.",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "openingCash": { "type": "number", "description": "Initial cash on hand" }
      }
    },
    "ProductMaster": {
      "title": "Product Master",
      "description": "Master list of product names and codes.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "productCode": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "dosage": { "type": "string" },
        "unitCount": { "type": "string" },
        "dosageForm": { "type": "string" },
        "type": { "type": "string", "enum": ["Packing", "Travel"], "description": "Product type (Packing or Travel)" }
      },
      "required": ["name", "productCode", "type"]
    },
    "Backup": {
      "title": "Backup",
      "description": "Database backup records.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "data": { "type": "object", "description": "Serialized backup data" },
        "totalRecords": { "type": "number" },
        "collections": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["success", "failed"] },
        "isAuto": { "type": "boolean" }
      },
      "required": ["timestamp", "data", "status"]
    },
    "Partner": {
      "title": "Partner",
      "description": "Business partners/shareholders.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "share": { "type": "number", "description": "Equity percentage" },
        "investment": { "type": "number", "description": "Investment amount" },
        "joinedAt": { "type": "string", "format": "date-time" },
        "note": { "type": "string" }
      },
      "required": ["name", "share", "investment"]
    }
  },
  "firestore": {
    "/products": { "schema": "Product", "description": "Inventory products" },
    "/purchases": { "schema": "Purchase", "description": "Purchase history" },
    "/sales": { "schema": "Sale", "description": "Sales history" },
    "/customers": { "schema": "Customer", "description": "CRM data" },
    "/suppliers": { "schema": "Supplier", "description": "Suppliers list" },
    "/categories": { "schema": "Category", "description": "Product categories" },
    "/expenses": { "schema": "Expense", "description": "Business expenses" },
    "/settings": { "schema": "Settings", "description": "App settings" },
    "/productMaster": { "schema": "ProductMaster", "description": "Master product list" },
    "/backups": { "schema": "Backup", "description": "Database backups" },
    "/partners": { "schema": "Partner", "description": "Business partners" }
  }
}
