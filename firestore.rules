rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - role: string (required, ['admin', 'user'])
    //   - email: string (required)
    //
    // Collection: products
    // Fields:
    //   - name: string (required, 1-200 chars)
    //   - categoryId: string (optional)
    //   - supplierId: string (optional)
    //   - average_cost_price: number (required, >= 0)
    //   - current_selling_price: number (required, >= 0)
    //   - total_stock: number (required)
    //   - createdAt: timestamp (immutable)
    //
    // Collection: sales
    // Fields:
    //   - orderNumber: string (required)
    //   - date: string (required, ISO 8601)
    //   - customerId: string (required)
    //   - items: list (required, max 50 items) - each item: {product_id, qty, sold_price_snapshot, cost_price_snapshot}
    //   - totalAmount: number (required, >= 0)
    //   - subtotal: number (optional)
    //   - deliveryFees: number (optional)
    //   - note: string (optional)
    //
    // Collection: purchases
    // Fields:
    //   - date: string (required)
    //   - product_id: string (required)
    //   - qty: number (required)
    //   - purchase_price: number (required)
    //   - totalAmount: number (required)
    //
    // Collection: inventory_logs
    // Fields:
    //   - productId: string
    //   - productName: string
    //   - type: string (IN, OUT, ADJUST)
    //   - quantity: number
    //   - referenceId: string
    //   - reason: string
    //   - date: timestamp
    //   - previousQty: number
    //   - newQty: number
    //
    // Collection: customers
    // Fields:
    //   - facebookName: string (required, 1-100 chars)
    //   - points: number (optional)
    //
    // Collection: suppliers
    // Fields:
    //   - name: string (required, 1-100 chars)
    //
    // Collection: categories
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - parent: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "diginestt2026@gmail.com" && request.auth.token.email_verified == true) ||
          (request.auth.token.email == "myatbinance@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= min && 
             request.resource.data[field].size() <= max;
    }

    function isValidOptionalString(field, max) {
      return !(field in request.resource.data) || 
             (request.resource.data[field] is string && request.resource.data[field].size() <= max);
    }

    function isPositive(field) {
      return request.resource.data[field] is number && request.resource.data[field] >= 0;
    }

    function isRecent(field) {
      return request.resource.data[field] is timestamp && 
             request.resource.data[field] > request.time - duration.value(5, 'm') &&
             request.resource.data[field] <= request.time;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidProduct(data) {
      return hasRequiredFields(['name', 'average_cost_price', 'current_selling_price', 'total_stock']) &&
             isValidString('name', 1, 200) &&
             isValidOptionalString('productCode', 50) &&
             isValidOptionalString('brand', 100) &&
             isValidOptionalString('dosage', 100) &&
             isValidOptionalString('unitCount', 100) &&
             isValidOptionalString('dosageForm', 100) &&
             isValidOptionalString('expiryDate', 10) &&
             isValidOptionalString('purchaseDate', 20) &&
             isValidOptionalString('supplierId', 50) &&
             isValidOptionalString('categoryId', 50) &&
             isPositive('average_cost_price') &&
             isPositive('current_selling_price') &&
             data.total_stock is number;
    }

    function isValidSale(data) {
      return hasRequiredFields(['order_no', 'date', 'customer_id', 'items', 'gross_amount', 'tax_amount', 'net_amount', 'total_amount']) &&
             isValidString('order_no', 1, 50) &&
             data.items is list && data.items.size() <= 50 &&
             isPositive('gross_amount') &&
             isPositive('tax_amount') &&
             isPositive('net_amount') &&
             isPositive('total_amount');
    }

    function isValidPurchase(data) {
      return hasRequiredFields(['date', 'product_id', 'qty', 'purchase_price', 'current_selling_price', 'total_amount']) &&
             isValidString('date', 1, 30) &&
             isValidString('product_id', 1, 50) &&
             isValidOptionalString('supplierId', 50) &&
             isValidOptionalString('categoryId', 50) &&
             isValidOptionalString('expiryDate', 10) &&
             isValidOptionalString('productCode', 50) &&
             isPositive('qty') &&
             isPositive('total_amount') &&
             isPositive('purchase_price') &&
             isPositive('current_selling_price');
    }

    function isValidInventoryLog(data) {
      return hasRequiredFields(['product_id', 'productName', 'type', 'qty', 'reason', 'date']) &&
             isValidString('product_id', 1, 50) &&
             isValidString('productName', 1, 200) &&
             (data.type == 'IN' || data.type == 'OUT' || data.type == 'ADJUST') &&
             data.qty is number &&
             isValidString('reason', 1, 500) &&
             data.date is timestamp;
    }

    function isValidCustomer(data) {
      return hasRequiredFields(['facebookName']) &&
             isValidString('facebookName', 1, 100);
    }

    function isValidExpense(data) {
      return hasRequiredFields(['date', 'amount', 'category']) &&
             isPositive('amount');
    }

    function isValidCategory(data) {
      return hasRequiredFields(['name']) &&
             isValidString('name', 1, 100);
    }

    function isValidSupplier(data) {
      return hasRequiredFields(['name']) &&
             isValidString('name', 1, 100);
    }

    function isValidProductMaster(data) {
      return hasRequiredFields(['name', 'productCode']) &&
             isValidString('name', 1, 200) &&
             isValidString('productCode', 1, 50) &&
             isValidOptionalString('brand', 100) &&
             isValidOptionalString('category', 100) &&
             isValidOptionalString('dosage', 100) &&
             isValidOptionalString('unitCount', 100) &&
             isValidOptionalString('dosageForm', 100) &&
             (!( 'type' in data) || data.type == 'Packing' || data.type == 'Travel');
    }

    function isValidBackup(data) {
      return hasRequiredFields(['timestamp', 'data', 'status']) &&
             (data.status == 'success' || data.status == 'failed');
    }

    function isValidPartner(data) {
      return hasRequiredFields(['name', 'share', 'investment']) &&
             isValidString('name', 1, 100) &&
             isValidOptionalString('email', 100) &&
             isValidOptionalString('phone', 50) &&
             isPositive('share') &&
             isPositive('investment');
    }

    // ===============================================================
    // Match Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow write: if isAdmin(); // Only admins can manage roles
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidProduct(request.resource.data);
      allow update: if isAuthenticated() && isValidProduct(request.resource.data) && 
                    (!('createdAt' in resource.data) || request.resource.data.createdAt == resource.data.createdAt);
      allow delete: if isAdmin();
    }

    match /purchases/{purchaseId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidPurchase(request.resource.data);
      allow delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidSale(request.resource.data);
      allow delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidCustomer(request.resource.data);
      allow delete: if isAdmin();
    }

    match /suppliers/{supplierId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidSupplier(request.resource.data);
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidCategory(request.resource.data);
      allow delete: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidExpense(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /productMaster/{productId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidProductMaster(request.resource.data);
      allow delete: if isAdmin();
    }

    match /backups/{backupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidBackup(request.resource.data);
      allow update: if false; // Backups should be immutable
      allow delete: if isAdmin();
    }

    match /partners/{partnerId} {
      allow read, delete: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidPartner(request.resource.data);
    }

    match /inventory_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidInventoryLog(request.resource.data);
      allow update, delete: if false; // Logs should be immutable
    }
  }
}
